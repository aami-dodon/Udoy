# Client/Server ports for local docker-compose
CLIENT_PORT=6004
SERVER_PORT=6005
# Hostnames used within docker compose networking
SERVER_HOST=udoy.dodon.in
CLIENT_HOST=udoy.dodon.in

# Databases
POSTGRES_URL=postgres://sayabasu:%211Dilbert@192.168.1.3:5432/udoy_dev_db
MONGO_URI=mongodb://sayabasu:%211Dilbert@192.168.1.3:27017/udoy_dev_db?authSource=admin

# Object storage (MinIO)
MINIO_ENDPOINT=cdn.dodon.in
MINIO_PORT=2000
MINIO_ACCESS_KEY=sayabasu
MINIO_SECRET_KEY=!1Dilbert
MINIO_BUCKET=udoy-dev-bucket
MINIO_USE_SSL=false
MINIO_PRESIGNED_URL_EXPIRY_SECONDS=900

# CORS
CORS_ALLOWED_ORIGINS=https://udoy.dodon.in
CORS_ALLOW_CREDENTIALS=false

# Auth settings
JWT_SECRET=supersecretjwt
JWT_EXPIRES_IN=1d
APP_BASE_URL=https://udoy.dodon.in

# Client <-> server communication
PUBLIC_API_BASE_URL=https://udoy.dodon.in

# Security / rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_SIGNUP=5
RATE_LIMIT_MAX_LOGIN=10
RATE_LIMIT_MAX_FORGOT_PASSWORD=5
RATE_LIMIT_MAX_RESET_PASSWORD=10

# Logging
LOG_LEVEL=debug

# Admin seed (optional)
ADMIN_NAME=Platform Admin
ADMIN_EMAIL=aami@dodon.in
ADMIN_PASSWORD=!1Dilbert
ADMIN_ROLE=admin

# SMTP / email support
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=aami@dodon.in
SMTP_PASSWORD=fPgCjy6HdBNh
SMTP_SECURE=true
SMTP_FROM="aami@dodon.in"
SUPPORT_EMAIL=support@udoy.dev

# Docker compose will inject the rest (e.g. MINIO endpoints) as needed
