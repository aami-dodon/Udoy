# Client/Server ports for local docker-compose
CLIENT_PORT=3000
SERVER_PORT=5000
SERVER_HOST=server
CLIENT_HOST=client

# Databases
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/udoy_dev
MONGO_URI=mongodb://mongo:password@localhost:27017/udoy_dev?authSource=admin

# Object storage (MinIO)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioaccess
MINIO_SECRET_KEY=miniosecret
MINIO_BUCKET=udoy-dev-bucket
MINIO_USE_SSL=false

# Auth settings
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d
APP_BASE_URL=http://localhost:3000

# Admin seed (optional)
ADMIN_NAME=Platform Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_ROLE=admin

# SMTP / email support
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=super-secret
SMTP_SECURE=true
SMTP_FROM="Udoy <no-reply@example.com>"
SUPPORT_EMAIL=support@example.com

# Docker compose will inject the rest (e.g. MINIO endpoints) as needed
