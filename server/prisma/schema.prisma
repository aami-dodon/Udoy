generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

enum Role {
  student
  teacher
  admin
}

enum TokenType {
  verify_email
  reset_password
}

model User {
  id                String      @id @default(uuid()) @db.Uuid
  name              String
  email             String      @unique
  emailNormalized   String      @unique @map("email_normalized")
  passwordHash      String      @map("password_hash")
  role              Role        @default(student)
  isVerified        Boolean     @default(false) @map("is_verified")
  isActive          Boolean     @default(true) @map("is_active")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  passwordUpdatedAt DateTime?   @map("password_updated_at")
  deletedAt         DateTime?   @map("deleted_at")
  tokens            UserToken[]
  auditLogsActor    AuditLog[]  @relation("AuditActor")
  auditLogsTarget   AuditLog[]  @relation("AuditTarget")

  @@map("users")
}

model UserToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @unique
  type      TokenType
  metadata  Json      @default("{}")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  usedAt    DateTime? @map("used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "user_tokens_user_id_idx")
  @@index([expiresAt], name: "user_tokens_expires_at_idx")
  @@map("user_tokens")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorId      String?  @map("actor_id") @db.Uuid
  targetUserId String?  @map("target_user_id") @db.Uuid
  action       String
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  actor      User? @relation("AuditActor", fields: [actorId], references: [id])
  targetUser User? @relation("AuditTarget", fields: [targetUserId], references: [id])

  @@index([actorId], name: "audit_logs_actor_id_idx")
  @@index([targetUserId], name: "audit_logs_target_user_id_idx")
  @@index([createdAt], name: "audit_logs_created_at_idx")
  @@map("audit_logs")
}
